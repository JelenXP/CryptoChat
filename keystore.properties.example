# Šablona pro podpis release APK vlastním klíčem.
#
# Postup:
#  1) Vygeneruj si keystore (spouštíš TY, keytool se zeptá na hesla - do gitu
#     ani ke mně se nedostanou). V kořeni projektu spusť:
#
#       keytool -genkeypair -v -keystore release.keystore -alias cryptochat \
#         -keyalg RSA -keysize 2048 -validity 10000
#
#     (na Windows PowerShell místo koncových "\" napiš vše na jeden řádek)
#
#  2) Zkopíruj tento soubor na "keystore.properties" (bez .example) a vyplň
#     hodnoty níže. keystore.properties i *.keystore jsou v .gitignore.
#
#  3) Sestav podepsané release APK:
#
#       .\gradlew.bat assembleRelease
#
# Cesta storeFile je relativní ke kořeni projektu (nebo absolutní).

storeFile=release.keystore
storePassword=ZDE_HESLO_KE_KEYSTORU
keyAlias=cryptochat
keyPassword=ZDE_HESLO_KE_KLICI
